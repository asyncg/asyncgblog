---
import Breadcrumbs from "@/components/Breadcrumbs.astro"
import Link from "@/components/Link.astro"
import PageHead from "@/components/PageHead.astro"
import { buttonVariants } from "@/components/ui/button"
import Layout from "@/layouts/Layout.astro"
import { cn } from "@/lib/utils"
---

<Layout class="max-w-4xl">
  <PageHead slot="head" title="404" />
  <Breadcrumbs items={[{ label: "404", icon: "lucide:triangle-alert" }]} />
  <section class="relative overflow-hidden px-6 py-12 sm:px-10">
    <div class="noise pointer-events-none absolute inset-0 opacity-[0.05]">
    </div>
    <div class="grid gap-12 md:grid-cols-[1.3fr_0.7fr] md:items-start">
      <div class="space-y-8">
        <div
          class="bg-foreground text-background inline-flex items-center gap-3 px-3 py-1.5 font-mono text-xs tracking-widest"
        >
          ERROR 404
        </div>
        <h1 class="font-mono text-6xl leading-[0.9] tracking-tight sm:text-7xl">
          404
          <span
            class="mt-3 block font-sans text-2xl font-medium tracking-normal sm:text-3xl"
          >
            Page not found
          </span>
        </h1>
        <div class="max-w-lg space-y-3">
          <p class="text-lg">The page you are looking for does not exist.</p>
          <p class="font-mono text-sm opacity-70">
            It may have moved. It may have never existed. It may be shown in the
            next episode of Dragon Ball Z
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-4">
          <Link
            href="/"
            class={cn(
              buttonVariants({ variant: "ghost" }),
              "brutal-link group",
            )}
          >
            <span class="transition-transform group-hover:-translate-x-1"
              >&larr;</span
            >
            <span class="ml-2">Go to home page</span>
          </Link>
          <div class="font-mono text-xs opacity-60">/???</div>
        </div>
      </div>
      <aside class="space-y-6">
        <div class="bg-muted/40 p-4">
          <div
            class="flex items-center justify-between font-mono text-xs tracking-widest"
          >
            <span>HACHIWARE</span>
            <span class="opacity-50">gif</span>
          </div>
          <div class="mt-4 overflow-hidden">
            <img
              src="/static/hachiware/eating.gif"
              alt="Hachiware eating"
              class="h-auto w-full"
              loading="eager"
              decoding="async"
            />
          </div>
          <p class="mt-4 font-mono text-xs leading-relaxed">
            This is how my girlfriend eats btw. I love her so much!
          </p>
        </div>
      </aside>
    </div>
  </section>

  <style>
    .noise {
      background-image: radial-gradient(
        circle at 1px 1px,
        var(--foreground) 1px,
        transparent 0
      );
      background-size: 6px 6px;
      mix-blend-mode: multiply;
    }
    :where([data-theme="dark"], [data-theme="dark"] *) .noise {
      mix-blend-mode: overlay;
    }
    @media (prefers-reduced-motion: no-preference) {
      .noise {
        animation: jitter 2.4s steps(2, end) infinite;
      }
      @keyframes jitter {
        0% {
          transform: translate3d(0, 0, 0);
        }
        25% {
          transform: translate3d(1px, -1px, 0);
        }
        50% {
          transform: translate3d(-1px, 1px, 0);
        }
        75% {
          transform: translate3d(1px, 1px, 0);
        }
        100% {
          transform: translate3d(0, 0, 0);
        }
      }
    }
  </style>
</Layout>
