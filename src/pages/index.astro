---
import BlogCard from "@/components/BlogCard.astro"
import Link from "@/components/Link.astro"
import PageHead from "@/components/PageHead.astro"
import { buttonVariants } from "@/components/ui/button"
import { SITE } from "@/consts"
import Layout from "@/layouts/Layout.astro"
import { getRecentPosts } from "@/lib/data-utils"
import { cn } from "@/lib/utils"

const blog = await getRecentPosts(SITE.featuredPostCount)
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Home" />
  <section class="mt-10">
    <div class="flex flex-col items-center text-center">
      <img
        src="/static/logo.svg"
        alt="asyncg logo"
        class="bg-background border-foreground h-24 w-24 rounded-full border-2 p-3"
        loading="eager"
        decoding="async"
      />
      <h1 class="mt-6 text-3xl font-semibold tracking-tight">asyncg</h1>
      <div class="text-muted-foreground mt-3 text-sm">
        <p>
          Hey there, stranger!
          <br />
          I am Avijeet, an undergrad student and a developer
        </p>
        <p class="mt-2">
          I enjoy turning what I learn into something others can learn from, and
          this is my little corner on the internet
        </p>
      </div>
    </div>
    <div class="mt-10 flex flex-col gap-y-4">
      <h2 class="text-2xl font-medium">Recent Posts</h2>
      <ul class="flex flex-col gap-y-4">
        {
          blog.map((post) => (
            <li>
              <BlogCard entry={post} />
            </li>
          ))
        }
      </ul>
      <div class="flex justify-center">
        <Link
          href="/blog"
          class={cn(buttonVariants({ variant: "ghost" }), "brutal-link group")}
        >
          See all posts
          <span class="ml-1.5 transition-transform group-hover:translate-x-1">
            →
          </span>
        </Link>
      </div>
    </div>
  </section>
</Layout>
